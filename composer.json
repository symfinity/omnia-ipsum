{
    "name": "symfinity/omnia-ipsum",
    "description": "All-in-One Placeholder Bundle for Symfony - placeholder images, Lorem Ipsum text, and fake data for rapid prototyping",
    "type": "symfony-bundle",
    "license": "MIT",
    "homepage": "https://github.com/symfinity/omnia-ipsum",
    "support": {
        "issues": "https://github.com/symfinity/omnia-ipsum/issues",
        "source": "https://github.com/symfinity/omnia-ipsum"
    },
    "authors": [
        {
            "name": "Symfinity",
            "email": "dev@symfinity.net",
            "homepage": "https://symfinity.net/"
        }
    ],
    "keywords": [
        "symfony",
        "symfony-bundle",
        "placeholder",
        "lorem-ipsum",
        "faker",
        "prototyping"
    ],
    "require": {
        "php": ">=8.1",
        "fakerphp/faker": "^1.23",
        "symfony/config": "^6.4||^7.0||^8.0",
        "symfony/console": "^6.4||^7.0||^8.0",
        "symfony/dependency-injection": "^6.4||^7.0||^8.0",
        "symfony/http-kernel": "^6.4||^7.0||^8.0",
        "symfony/twig-bundle": "^6.4||^7.0||^8.0",
        "twig/twig": "^3.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-symfony": "^2.0",
        "phpunit/phpunit": "^10.5 || ^11.0",
        "symfony/yaml": "^6.4||^7.0||^8.0"
    },
    "replace": {
        "neuralglitch/omnia-ipsum": "*"
    },
    "autoload": {
        "psr-4": {
            "Symfinity\\OmniaIpsum\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Symfinity\\OmniaIpsum\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse --memory-limit=512M"
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        },
        "symfony": {
            "require": "^6.4||^7.0||^8.0"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
